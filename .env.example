# =============================================================================
# CARMANIA Landing — variables de entorno
#
# Copiá este archivo a `.env.local` y rellená los valores.
# En Vercel: Settings → Environment Variables (los mismos nombres).
# =============================================================================

# --- SHOPIFY STOREFRONT API ----------------------------------------------------
# Subdominio .myshopify.com de la tienda (NO el dominio custom).
NEXT_PUBLIC_SHOPIFY_DOMAIN=carmania-9625.myshopify.com

# Token PÚBLICO de la Storefront API (de la app Headless o Custom App).
# Sí, es público — está pensado para vivir en el cliente.
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=40713e31c177219dad9d6d23ee103513

# Versión de la API. Subimos cuando hay features nuevas que necesitemos.
NEXT_PUBLIC_SHOPIFY_API_VERSION=2025-01

# --- TRACKING ------------------------------------------------------------------
# Meta Pixel ID (de Facebook Business Manager → Events Manager).
# Si no querés trackear todavía, dejalo vacío.
NEXT_PUBLIC_META_PIXEL_ID=877870938398833
